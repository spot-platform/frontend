# Optional: enable development-only dummy login
# ENABLE_DEV_DUMMY_LOGIN=true

# Naver Map API client ID (optional — falls back to MockMapCanvas when absent)
# NEXT_PUBLIC_NAVER_MAP_CLIENT_KEY=

# map-v3 — 네이버 지도 Custom Style (라이트/다크). 값은 Naver Cloud Console 에서 발급.
NEXT_PUBLIC_NAVER_MAP_STYLE_LIGHT=
NEXT_PUBLIC_NAVER_MAP_STYLE_DARK=
